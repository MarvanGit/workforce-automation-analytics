# This file documents expected environment variables.
# Copy to .env locally when implementation begins.

# Backend
APP_NAME=Workforce Automation Analytics
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:4200

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=workforce_analytics
POSTGRES_USER=workforce
POSTGRES_PASSWORD=workforce
DATABASE_URL=postgresql+asyncpg://workforce:workforce@postgres:5432/workforce_analytics

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Google Sheets integration
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_AVAILABILITY_RANGE=Availability!A:F
GOOGLE_APPLICATION_CREDENTIALS=

